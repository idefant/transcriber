# Example environment variables.
# Copy this file to .env and fill in the values: `cp .env.example .env`
# .env is gitignored - never commit real secrets.

# --- Model testing (scripts/model-testing) ---
# API keys consumed by `npm run model-test`.
# See docs/development/model-testing.md.
OPENAI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# --- Sentry (optional) ---
# Leave all values empty to disable telemetry safely. VITE_SENTRY_DSN is public
# and is embedded in the frontend; SENTRY_DSN is read only while compiling Rust.
VITE_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT_REACT=
SENTRY_PROJECT_RUST=
