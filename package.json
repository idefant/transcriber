{
  "name": "transcriber",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "tauri": "tauri",
    "dev:tauri": "cross-env WEBVIEW2_ADDITIONAL_BROWSER_ARGUMENTS=--unsafely-disable-devtools-self-xss-warnings tauri dev --config src-tauri/tauri.dev.conf.json",
    "dev:tauri:debug": "cross-env WEBVIEW2_ADDITIONAL_BROWSER_ARGUMENTS=\"--unsafely-disable-devtools-self-xss-warnings --remote-debugging-port=9222\" tauri dev --config src-tauri/tauri.dev.conf.json",
    "build:tauri": "tauri build",
    "build:tauri:canary": "cross-env VITE_APP_CHANNEL=canary tauri build --config src-tauri/tauri.canary.conf.json",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "stylelint": "stylelint \"src/**/*.{css,scss}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,scss}\" --fix",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "rust:fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --all --check",
    "rust:lint": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "rust:check": "npm run rust:fmt:check && npm run rust:lint",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "encoding:check": "node scripts/check-encoding.mjs",
    "model-test": "node scripts/model-testing/run.mjs",
    "model-test:smoke": "node scripts/model-testing/run.mjs --smoke",
    "check": "npm run typecheck && npm run lint && npm run stylelint && npm run format:check && npm run encoding:check && npm run rust:check && npm run build",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@sentry/react": "^10.66.0",
    "@tauri-apps/api": "^2.11.0",
    "antd": "^6.4.4",
    "clsx": "^2.1.1",
    "dayjs": "1.11.21",
    "i18next": "^26.3.1",
    "lodash-es": "^4.18.1",
    "lucide-react": "^1.18.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router": "7.17.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "^1.60.0",
    "@sentry/cli": "^3.6.0",
    "@sentry/vite-plugin": "^5.4.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tauri-apps/cli": "^2.11.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "cross-env": "^10.1.0",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-regexp": "3.1.0",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-storybook": "^10.4.6",
    "eslint-plugin-unicorn": "65.0.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "playwright": "^1.61.1",
    "prettier": "3.8.4",
    "sass": "1.101.0",
    "storybook": "^10.4.6",
    "stylelint": "17.13.0",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-order": "8.1.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vite": "8.0.16",
    "vite-plugin-checker": "0.14.1",
    "vitest": "^4.1.9"
  }
}
