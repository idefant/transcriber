{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Transcriber",
  "version": "0.1.0",
  "identifier": "com.transcriber.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Transcriber",
        "width": 1100,
        "height": 700,
        "minWidth": 1080,
        "minHeight": 600,
        "visible": false,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Russian", "English"],
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBMzNDNTQ3MDk1NzU1RDMKUldUVFZWY0pSOFV6Mm80N0NCMi9hU2U0azJ5UmRUclRicE9kcDhsOHFucm5ONk1DdlA1RUROS3YK",
      "endpoints": ["https://idefant.github.io/transcriber/stable.json"],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
